PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/socratic_ai?retryWrites=true&w=majority
CLIENT_URL=http://localhost:3000

# ── Hugging Face ─────────────────────────────────────────────────────────
# Get your free token at: https://huggingface.co/settings/tokens
# Required permission: "Make calls to the serverless Inference API"
HF_TOKEN=hf_your_token_here

# Optional: override the default model
# Free tier options:
#   meta-llama/Llama-3.1-8B-Instruct   ← default (best reasoning)
#   mistralai/Mistral-7B-Instruct-v0.3  ← lighter/faster
# PRO tier:
#   meta-llama/Llama-3.3-70B-Instruct   ← most capable
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
